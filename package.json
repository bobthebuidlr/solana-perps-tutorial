{
  "name": "perps-dex",
  "scripts": {
    "anchor-build": "cd anchor && anchor build",
    "anchor-test": "cd anchor && anchor test",
    "anchor-deploy": "cd anchor && anchor deploy",
    "build": "next build",
    "ci": "npm run build && npm run lint && npm run format:check",
    "codama:js": "codama run js",
    "create-markets": "tsx anchor/scripts/create-markets.ts",
    "dev": "next dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "init-program": "tsx anchor/scripts/initialize.ts",
    "lint": "eslint",
    "setup": "npm run anchor-build && npm run codama:js",
    "start": "next start",
    "workflow": "npm run anchor-build && npm run anchor-deploy && npm run init-program && npm run create-markets"
  },
  "description": "Next.js, Tailwind, @solana/react-hooks, Anchor vault program",
  "keywords": [
    "anchor",
    "kit",
    "nextjs",
    "react",
    "solana-kit",
    "tailwind",
    "typescript"
  ],
  "version": "0.0.0",
  "private": true,
  "dependencies": {
    "@solana/client": "^1.2.0",
    "@solana/kit": "^5.1.0",
    "@solana/react-hooks": "^1.1.5",
    "next": "16.0.10",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@codama/nodes-from-anchor": "^1.3.8",
    "@codama/renderers-js": "^1.5.5",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "codama": "^1.5.0",
    "eslint": "^9",
    "eslint-config-next": "16.0.10",
    "prettier": "^3.6.2",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
